{%- comment -%}
  Pre-order countdown.

  Renders only when the product has a "Pre-order ends" date set
  (custom.preorder_ends_at). Products without a date show nothing at all, so this
  snippet is safe to render on every product page.

  The deadline is passed to JS as epoch seconds, which is timezone-independent —
  the human-readable line below it is formatted in the shop's timezone.

  Once the deadline passes the clock is replaced by a closed message and the
  add-to-cart button is disabled. That happens server-side on load for anyone
  arriving after the deadline, and live via the ticker for anyone already on the
  page when it runs out.

  Usage: {% render 'preorder-countdown', product: product %}
{%- endcomment -%}

{%- assign po_field = product.metafields.custom.preorder_ends_at -%}

{%- if po_field.value != blank -%}
  {%- assign po_end_ts = po_field.value | date: '%s' | times: 1 -%}
  {%- assign po_now_ts = 'now' | date: '%s' | times: 1 -%}
  {%- assign po_closed = false -%}
  {%- if po_end_ts <= po_now_ts -%}
    {%- assign po_closed = true -%}
  {%- endif -%}

  {%- comment -%} Under 24h left reads as "closing soon" — set server-side so there is no flash. {%- endcomment -%}
  {%- assign po_secs_left = po_end_ts | minus: po_now_ts -%}
  {%- assign po_urgent = false -%}
  {%- if po_closed == false and po_secs_left < 86400 -%}
    {%- assign po_urgent = true -%}
  {%- endif -%}

  <div class="preorder-timer{% if po_closed %} is-closed{% endif %}{% if po_urgent %} is-urgent{% endif %}"
       data-preorder-timer
       data-ends="{{ po_end_ts }}">

    <div class="preorder-timer__head">
      <span class="preorder-timer__pip" aria-hidden="true"></span>
      <p class="preorder-timer__label" data-po-label>
        {%- if po_closed -%}Pre-order closed{%- elsif po_urgent -%}Closing soon{%- else -%}Pre-order closes in{%- endif -%}
      </p>
    </div>

    <div class="preorder-timer__clock" data-po-clock{% if po_closed %} hidden{% endif %} role="timer" aria-live="off">
      <div class="preorder-timer__cell"><b data-po-days>00</b><i>Days</i></div>
      <div class="preorder-timer__cell"><b data-po-hours>00</b><i>Hrs</i></div>
      <div class="preorder-timer__cell"><b data-po-mins>00</b><i>Min</i></div>
      <div class="preorder-timer__cell"><b data-po-secs>00</b><i>Sec</i></div>
    </div>

    <p class="preorder-timer__note" data-po-note>
      {%- if po_closed -%}
        This pre-order window has ended.
      {%- else -%}
        Closes {{ po_field.value | date: '%-d %b %Y, %-I:%M %p' }}
      {%- endif -%}
    </p>
  </div>

  <style>
    .preorder-timer {
      --po-accent: #a78a5e;
      --po-ink: #2a2320;
      --po-muted: #8f8579;
      --po-line: #e5dfd4;
      position: relative;
      margin: 22px 0 26px;
      padding: 17px 20px 15px;
      background: linear-gradient(180deg, #fdfbf7 0%, #f7f3ea 100%);
      border: 1px solid var(--po-line);
      border-radius: 2px;
      font-family: var(--font-body, 'Jost', sans-serif);
    }
    /* Hairline of colour along the top edge, fading out to the right. */
    .preorder-timer::before {
      content: '';
      position: absolute;
      inset: 0 0 auto 0;
      height: 2px;
      background: linear-gradient(90deg, var(--po-accent) 0%, rgba(167,138,94,0.35) 45%, rgba(167,138,94,0) 100%);
    }

    .preorder-timer__head {
      display: flex;
      align-items: center;
      gap: 8px;
      margin: 0 0 14px;
    }
    .preorder-timer__pip {
      flex: none;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--po-accent);
    }
    .preorder-timer__label {
      margin: 0;
      font-size: 10.5px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--po-accent);
    }

    /* Four equal cells divided by hairlines — replaces the old floating colons,
       which never sat on the baseline cleanly. */
    .preorder-timer__clock {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
    .preorder-timer__clock[hidden] { display: none; }
    .preorder-timer__cell {
      position: relative;
      text-align: center;
      padding: 2px 4px;
    }
    .preorder-timer__cell + .preorder-timer__cell::before {
      content: '';
      position: absolute;
      left: 0;
      top: 12%;
      height: 58%;
      width: 1px;
      background: var(--po-line);
    }
    .preorder-timer__cell b {
      display: block;
      font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
      font-size: 34px;
      font-weight: 500;
      line-height: 1;
      color: var(--po-ink);
      /* Tabular figures stop the seconds jittering the layout every tick. */
      font-variant-numeric: tabular-nums;
      font-feature-settings: "tnum" 1;
    }
    .preorder-timer__cell i {
      display: block;
      margin-top: 7px;
      font-style: normal;
      font-size: 8.5px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--po-muted);
    }

    .preorder-timer__note {
      margin: 14px 0 0;
      padding-top: 12px;
      border-top: 1px solid var(--po-line);
      font-size: 11.5px;
      color: var(--po-muted);
    }

    /* Under 24 hours: warmer accent and a slow pulse on the pip. */
    .preorder-timer.is-urgent { --po-accent: #b4553a; }
    .preorder-timer.is-urgent .preorder-timer__pip {
      animation: po-pulse 1.8s ease-in-out infinite;
    }
    @keyframes po-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.3; transform: scale(0.75); }
    }

    .preorder-timer.is-closed {
      --po-accent: #9a9188;
      background: #f6f5f3;
      border-color: #e3e1dd;
    }
    .preorder-timer.is-closed::before { background: #ddd9d2; }
    .preorder-timer.is-closed .preorder-timer__note { border-top-color: #e3e1dd; }

    @media (max-width: 480px) {
      .preorder-timer { padding: 15px 16px 13px; }
      .preorder-timer__cell b { font-size: 28px; }
      .preorder-timer__cell i { font-size: 8px; letter-spacing: 0.12em; }
    }
    @media (prefers-reduced-motion: reduce) {
      .preorder-timer__pip { animation: none !important; }
    }
  </style>

  <script>
    (function () {
      var root = document.querySelector('[data-preorder-timer]');
      if (!root) return;

      var endsMs  = parseInt(root.getAttribute('data-ends'), 10) * 1000;
      var clock   = root.querySelector('[data-po-clock]');
      var label   = root.querySelector('[data-po-label]');
      var note    = root.querySelector('[data-po-note]');
      var out     = {
        d: root.querySelector('[data-po-days]'),
        h: root.querySelector('[data-po-hours]'),
        m: root.querySelector('[data-po-mins]'),
        s: root.querySelector('[data-po-secs]')
      };
      if (!endsMs) return;

      function pad(n) { return (n < 10 ? '0' : '') + n; }

      // Re-asserted on every tick: the buy button is rendered by a web component
      // that can re-evaluate its own disabled state, which would otherwise undo this.
      function lockBuying() {
        var btns = document.querySelectorAll('.pdp__add-to-cart');
        for (var i = 0; i < btns.length; i++) {
          var b = btns[i];
          b.disabled = true;
          b.setAttribute('aria-disabled', 'true');
          if (b.textContent.trim() !== 'Pre-order closed') b.textContent = 'Pre-order closed';
        }
      }

      function close() {
        root.classList.add('is-closed');
        if (clock) clock.hidden = true;
        if (label) label.textContent = 'Pre-order closed';
        if (note) note.textContent = 'This pre-order window has ended.';
        lockBuying();
      }

      function tick() {
        var left = endsMs - Date.now();
        if (left <= 0) { close(); return; }
        var secs = Math.floor(left / 1000);
        out.d.textContent = pad(Math.floor(secs / 86400));
        out.h.textContent = pad(Math.floor(secs % 86400 / 3600));
        out.m.textContent = pad(Math.floor(secs % 3600 / 60));
        out.s.textContent = pad(secs % 60);

        // Cross into the last 24 hours while the page is open.
        if (secs < 86400 && !root.classList.contains('is-urgent')) {
          root.classList.add('is-urgent');
          if (label) label.textContent = 'Closing soon';
        }
      }

      tick();
      setInterval(tick, 1000);
    })();
  </script>
{%- endif -%}
