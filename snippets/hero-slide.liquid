{%- comment -%}
  Renders one hero slide from prefixed settings (works on static sections).
  Params:
    s      - settings object (section.settings)
    prefix - setting id prefix, e.g. "slide1_"
    uid    - unique id for scoping styles
    eager  - true to prioritise image loading (first slide)
    active - true to mark this slide active on load
{%- endcomment -%}
{%- liquid
  assign prefix = prefix | default: ''
  assign k = prefix | append: 'image'
  assign image = s[k]
  assign k = prefix | append: 'image_mobile'
  assign image_mobile = s[k]
  assign k = prefix | append: 'focal_point'
  assign focal_point = s[k] | default: 'center center'
  assign k = prefix | append: 'overlay_opacity'
  assign overlay_opacity = s[k] | default: 0
  assign k = prefix | append: 'eyebrow'
  assign eyebrow = s[k]
  assign k = prefix | append: 'heading'
  assign heading = s[k]
  assign k = prefix | append: 'subheading'
  assign subheading = s[k]
  assign k = prefix | append: 'position_v'
  assign pos_v = s[k] | default: 'middle'
  assign k = prefix | append: 'position_h'
  assign pos_h = s[k] | default: 'center'
  assign k = prefix | append: 'text_alignment'
  assign txt_align = s[k] | default: pos_h
  assign k = prefix | append: 'offset_x'
  assign off_x = s[k] | default: 0
  assign k = prefix | append: 'offset_y'
  assign off_y = s[k] | default: 0
  assign k = prefix | append: 'eyebrow_size'
  assign eyebrow_size = s[k] | default: 11
  assign k = prefix | append: 'heading_size'
  assign heading_size = s[k] | default: 56
  assign k = prefix | append: 'subheading_size'
  assign subheading_size = s[k] | default: 15
  assign k = prefix | append: 'button_label'
  assign button_label = s[k]
  assign k = prefix | append: 'button_link'
  assign button_link = s[k]
  assign k = prefix | append: 'button_alignment'
  assign btn_align = s[k] | default: 'inherit'
  assign k = prefix | append: 'button_offset_x'
  assign btn_off_x = s[k] | default: 0
  assign k = prefix | append: 'button_offset_y'
  assign btn_off_y = s[k] | default: 0
  assign k = prefix | append: 'text_color'
  assign text_color = s[k] | default: '#4a2c2a'
  assign k = prefix | append: 'eyebrow_color'
  assign eyebrow_color = s[k] | default: '#a78a5e'
  assign k = prefix | append: 'button_bg_color'
  assign button_bg_color = s[k] | default: '#4a2c2a'
  assign k = prefix | append: 'button_text_color'
  assign button_text_color = s[k] | default: '#ffffff'

  assign has_image = false
  if image != blank
    assign has_image = true
  endif

  case pos_h
    when 'left'
      assign justify = 'flex-start'
    when 'right'
      assign justify = 'flex-end'
    else
      assign justify = 'center'
  endcase
  case pos_v
    when 'top'
      assign align = 'flex-start'
    when 'bottom'
      assign align = 'flex-end'
    else
      assign align = 'center'
  endcase
-%}

<style>
  #hero-slide-{{ uid }} {
    position: relative; width: 100%; min-height: inherit;
    display: flex; align-items: {{ align }}; justify-content: {{ justify }};
    text-align: {{ txt_align }}; overflow: hidden;
    {% unless has_image %}background: linear-gradient(135deg, #f5f1ea 0%, #e8e1d4 100%);{% endunless %}
  }
  #hero-slide-{{ uid }} .hero__media { position: absolute; inset: 0; z-index: 0; }
  #hero-slide-{{ uid }} .hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: {{ focal_point }}; display: block; }
  #hero-slide-{{ uid }} .hero__media--mobile { display: none; }
  #hero-slide-{{ uid }} .hero__overlay { position: absolute; inset: 0; z-index: 1; background: #000; opacity: {{ overlay_opacity | divided_by: 100.0 }}; pointer-events: none; }
  #hero-slide-{{ uid }} .hero__inner {
    position: relative; z-index: 2; padding: clamp(48px, 8vw, 96px) 24px; max-width: 720px;
    {% if pos_h == 'left' %}margin-left: clamp(24px, 6vw, 96px);{% elsif pos_h == 'right' %}margin-right: clamp(24px, 6vw, 96px);{% endif %}
    {% if pos_v == 'top' %}margin-top: clamp(24px, 6vw, 80px);{% elsif pos_v == 'bottom' %}margin-bottom: clamp(24px, 6vw, 80px);{% endif %}
    {% if off_x != 0 or off_y != 0 %}transform: translate({{ off_x }}%, {{ off_y }}%);{% endif %}
    color: {{ text_color }};
  }
  #hero-slide-{{ uid }} .hero__eyebrow { font-family: var(--font-body); font-size: {{ eyebrow_size }}px; letter-spacing: 0.28em; text-transform: uppercase; margin: 0 0 18px; color: {{ eyebrow_color }}; }
  #hero-slide-{{ uid }} .hero__title { font-family: var(--font-heading); font-style: italic; font-weight: 400; font-size: clamp(28px, 5vw, {{ heading_size }}px); line-height: 1.1; margin: 0 0 14px; color: inherit; }
  #hero-slide-{{ uid }} .hero__subtitle { font-family: var(--font-body); font-size: {{ subheading_size }}px; line-height: 1.5; {% if txt_align == 'center' %}margin: 0 auto;{% elsif txt_align == 'right' %}margin: 0 0 0 auto;{% else %}margin: 0;{% endif %} max-width: 540px; color: inherit; opacity: 0.92; }
  #hero-slide-{{ uid }} .hero__cta {
    {% if btn_align == 'inherit' %}display: inline-block;{% else %}display: block; width: -moz-fit-content; width: fit-content; {% if btn_align == 'left' %}margin-right: auto;{% elsif btn_align == 'right' %}margin-left: auto;{% else %}margin-left: auto; margin-right: auto;{% endif %}{% endif %}
    margin-top: 26px; padding: 13px 34px; font-family: var(--font-body); font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none;
    color: {{ button_text_color }}; background: {{ button_bg_color }}; border: 1px solid {{ button_bg_color }}; transition: opacity 0.25s ease, transform 0.25s ease;
    transform: translate({{ btn_off_x }}px, {{ btn_off_y }}px);
  }
  #hero-slide-{{ uid }} .hero__cta:hover { opacity: 0.88; transform: translate({{ btn_off_x }}px, calc({{ btn_off_y }}px - 1px)); }
  #hero-slide-{{ uid }} .hero__dims { display: inline-block; margin-top: 22px; padding: 6px 14px; font-family: var(--font-body); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-text-muted); background: rgba(255,255,255,0.6); border: 1px solid var(--color-border-light); }
  @media (max-width: 749px) {
    {% if image_mobile != blank %}
    #hero-slide-{{ uid }} .hero__media--desktop { display: none; }
    #hero-slide-{{ uid }} .hero__media--mobile { display: block; }
    {% endif %}
  }
</style>

<div id="hero-slide-{{ uid }}" class="hero-slide{% if active %} is-active{% endif %}{% unless has_image %} hero--placeholder{% endunless %}">
  {%- if has_image -%}
    <div class="hero__media hero__media--desktop">
      <img
        src="{{ image | image_url: width: 1920 }}"
        srcset="{{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1280 }} 1280w, {{ image | image_url: width: 1920 }} 1920w, {{ image | image_url: width: 2400 }} 2400w"
        sizes="100vw" alt="{{ image.alt | default: heading | escape }}" width="1920" height="900"
        {% if eager %}fetchpriority="high"{% else %}loading="lazy"{% endif %}
      >
    </div>
    {%- if image_mobile != blank -%}
      <div class="hero__media hero__media--mobile">
        <img src="{{ image_mobile | image_url: width: 900 }}" srcset="{{ image_mobile | image_url: width: 600 }} 600w, {{ image_mobile | image_url: width: 900 }} 900w, {{ image_mobile | image_url: width: 1200 }} 1200w" sizes="100vw" alt="{{ image_mobile.alt | default: heading | escape }}" width="900" height="1100" loading="lazy">
      </div>
    {%- endif -%}
    {%- if overlay_opacity > 0 -%}<div class="hero__overlay"></div>{%- endif -%}
  {%- endif -%}

  <div class="hero__inner">
    {%- if eyebrow != blank -%}<p class="hero__eyebrow">{{ eyebrow }}</p>{%- endif -%}
    {%- if heading != blank -%}<h2 class="hero__title">{{ heading }}</h2>
    {%- elsif has_image == false -%}<h2 class="hero__title">Add your campaign imagery here</h2>{%- endif -%}
    {%- if subheading != blank -%}<p class="hero__subtitle">{{ subheading }}</p>
    {%- elsif has_image == false -%}<p class="hero__subtitle">Choose an image and add a headline, then add a button below.</p>{%- endif -%}
    {%- if button_label != blank and button_link != blank -%}<a class="hero__cta" href="{{ button_link }}">{{ button_label }}</a>{%- endif -%}
    {%- unless has_image -%}<span class="hero__dims">Recommended: 1920 &times; 900</span>{%- endunless -%}
  </div>
</div>
