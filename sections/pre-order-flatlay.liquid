{%- comment -%} Pre-order story: flat-lay product shot on a colored field {%- endcomment -%}
<section class="po-flatlay" style="background:{{ section.settings.bg_color }};">
  <div class="po-flatlay__inner">
    {%- if section.settings.image != blank -%}
      <img class="po-flatlay__img" src="{{ section.settings.image | image_url: width: 1800 }}"
           srcset="{{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1800 }} 1800w"
           sizes="(min-width: 768px) 80vw, 100vw"
           alt="{{ section.settings.caption | default: 'Product' | escape }}" loading="lazy">
    {%- else -%}
      <div class="po-flatlay__placeholder">Add a flat-lay image</div>
    {%- endif -%}
    {%- if section.settings.caption != blank -%}
      <p class="po-flatlay__caption" style="color:{{ section.settings.text_color }};">{{ section.settings.caption }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.po-flatlay { padding: clamp(48px, 9vw, 120px) clamp(20px, 5vw, 64px); }
.po-flatlay__inner { max-width: 1200px; margin: 0 auto; text-align: center; }
.po-flatlay__img { width: 100%; height: auto; display: block; object-fit: contain; }
.po-flatlay__placeholder {
  min-height: 280px; display: grid; place-items: center;
  border: 1px dashed rgba(0,0,0,0.25); color: rgba(0,0,0,0.5);
  font-family: var(--font-body, sans-serif); letter-spacing: 0.05em;
}
.po-flatlay__caption { font-family: var(--font-body, 'Jost', sans-serif); letter-spacing: 0.04em; margin: 24px 0 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "Pre-order: Flat-lay",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Flat-lay image" },
    { "type": "text", "id": "caption", "label": "Caption (optional)", "default": "" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#c8702a" },
    { "type": "color", "id": "text_color", "label": "Caption text", "default": "#241405" }
  ],
  "presets": [ { "name": "Pre-order: Flat-lay" } ]
}
{% endschema %}
