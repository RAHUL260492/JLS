{%- liquid
  case section.settings.height
    when 'small'
      assign min_h = '46vh'
    when 'medium'
      assign min_h = '60vh'
    when 'large'
      assign min_h = '78vh'
    when 'full'
      assign min_h = '92vh'
    else
      assign min_h = '60vh'
  endcase

  assign has_main = false
  if section.settings.image != blank or section.settings.heading != blank
    assign has_main = true
  endif

  assign slide_count = section.blocks.size
  if has_main
    assign slide_count = slide_count | plus: 1
  endif
  if slide_count == 0
    assign slide_count = 1
  endif
-%}

<style>
  #hero-slideshow-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: {{ min_h }};
    overflow: hidden;
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
  }
  #hero-slideshow-{{ section.id }} .hero-slides { position: relative; width: 100%; min-height: {{ min_h }}; }
  #hero-slideshow-{{ section.id }} .hero-slide { position: absolute; inset: 0; opacity: 0; visibility: hidden; transition: opacity 0.8s ease; }
  #hero-slideshow-{{ section.id }} .hero-slide.is-active { opacity: 1; visibility: visible; z-index: 1; }
  #hero-slideshow-{{ section.id }}.is-single .hero-slide { position: relative; opacity: 1; visibility: visible; }
  #hero-slideshow-{{ section.id }} .hero--placeholder::before { content: ''; position: absolute; inset: 24px; border: 1px dashed rgba(74,44,42,0.25); pointer-events: none; z-index: 1; }

  #hero-slideshow-{{ section.id }} .hero-arrow {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 5;
    width: 44px; height: 44px; border: none; border-radius: 50%;
    background: rgba(255,255,255,0.82); color: #4a2c2a; font-size: 22px; line-height: 1;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 0.2s ease;
  }
  #hero-slideshow-{{ section.id }} .hero-arrow:hover { background: #fff; }
  #hero-slideshow-{{ section.id }} .hero-arrow--prev { left: 20px; }
  #hero-slideshow-{{ section.id }} .hero-arrow--next { right: 20px; }
  #hero-slideshow-{{ section.id }} .hero-dots { position: absolute; bottom: 22px; left: 0; right: 0; z-index: 5; display: flex; gap: 10px; justify-content: center; }
  #hero-slideshow-{{ section.id }} .hero-dot { width: 9px; height: 9px; border-radius: 50%; border: 1px solid #4a2c2a; background: transparent; padding: 0; cursor: pointer; transition: background 0.2s ease; }
  #hero-slideshow-{{ section.id }} .hero-dot.is-active { background: #4a2c2a; }
  @media (max-width: 749px) { #hero-slideshow-{{ section.id }} .hero-arrow { width: 36px; height: 36px; font-size: 18px; } }
</style>

<section id="hero-slideshow-{{ section.id }}" class="hero-slideshow{% if slide_count <= 1 %} is-single{% endif %}" aria-label="Hero banner" aria-roledescription="carousel">
  <div class="hero-slides">
    {%- if has_main -%}
      {% render 'hero-slide', s: section.settings, uid: section.id, eager: true, active: true %}
    {%- endif -%}
    {%- for block in section.blocks -%}
      {%- assign is_first = false -%}
      {%- if forloop.first and has_main == false -%}{%- assign is_first = true -%}{%- endif -%}
      {% render 'hero-slide', s: block.settings, uid: block.id, eager: forloop.first, active: is_first, attrs: block.shopify_attributes %}
    {%- endfor -%}
    {%- unless has_main or section.blocks.size > 0 -%}
      {% render 'hero-slide', s: section.settings, uid: section.id, eager: true, active: true %}
    {%- endunless -%}
  </div>

  {%- if slide_count > 1 -%}
    {%- if section.settings.show_arrows -%}
      <button class="hero-arrow hero-arrow--prev" type="button" aria-label="Previous slide">&lsaquo;</button>
      <button class="hero-arrow hero-arrow--next" type="button" aria-label="Next slide">&rsaquo;</button>
    {%- endif -%}
    {%- if section.settings.show_dots -%}
      <div class="hero-dots">
        {%- for n in (1..slide_count) -%}
          <button class="hero-dot{% if forloop.first %} is-active{% endif %}" type="button" aria-label="Go to slide {{ n }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

<script>
  (function () {
    var root = document.getElementById('hero-slideshow-{{ section.id }}');
    if (!root) return;
    var slides = Array.prototype.slice.call(root.querySelectorAll('.hero-slide'));
    var dots = Array.prototype.slice.call(root.querySelectorAll('.hero-dot'));
    if (slides.length < 2) { if (slides[0]) slides[0].classList.add('is-active'); return; }

    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var autoplay = {{ section.settings.autoplay | default: true }};
    var delay = {{ section.settings.autoplay_speed | default: 6 }} * 1000;
    var idx = Math.max(0, slides.findIndex(function (s) { return s.classList.contains('is-active'); }));
    var timer = null;

    function go(n) {
      slides[idx].classList.remove('is-active'); if (dots[idx]) dots[idx].classList.remove('is-active');
      idx = (n + slides.length) % slides.length;
      slides[idx].classList.add('is-active'); if (dots[idx]) dots[idx].classList.add('is-active');
    }
    function start() { stop(); if (autoplay && !reduce) timer = setInterval(function () { go(idx + 1); }, delay); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    var prev = root.querySelector('.hero-arrow--prev'); if (prev) prev.addEventListener('click', function () { go(idx - 1); start(); });
    var next = root.querySelector('.hero-arrow--next'); if (next) next.addEventListener('click', function () { go(idx + 1); start(); });
    dots.forEach(function (d, i) { d.addEventListener('click', function () { go(i); start(); }); });
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    start();

    // Theme editor: jump to the slide being edited
    document.addEventListener('shopify:block:select', function (e) {
      if (!root.contains(e.target)) return;
      var s = e.target.classList.contains('hero-slide') ? e.target : e.target.querySelector('.hero-slide');
      var i = slides.indexOf(s); if (i > -1) go(i); stop();
    });
    document.addEventListener('shopify:block:deselect', function (e) { if (root.contains(e.target)) start(); });
  })();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "max_blocks": 5,
  "settings": [
    { "type": "header", "content": "Slideshow" },
    { "type": "paragraph", "content": "Slide 1 is set below. Use “Add slide” to add more — they rotate automatically." },
    { "type": "checkbox", "id": "autoplay", "label": "Auto-rotate slides", "default": true },
    { "type": "range", "id": "autoplay_speed", "label": "Seconds per slide", "min": 3, "max": 10, "step": 1, "unit": "s", "default": 6 },
    { "type": "checkbox", "id": "show_arrows", "label": "Show arrows", "default": true },
    { "type": "checkbox", "id": "show_dots", "label": "Show dots", "default": true },
    {
      "type": "select", "id": "height", "label": "Slideshow height", "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full screen" }
      ]
    },
    { "type": "header", "content": "Slide 1 · Image" },
    { "type": "image_picker", "id": "image", "label": "Desktop image", "info": "Recommended 1920 × 900" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile image (optional)", "info": "Recommended a taller crop, e.g. 900 × 1100" },
    {
      "type": "select", "id": "focal_point", "label": "Image focal point", "default": "center center",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ]
    },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay darkness", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 0, "info": "Darkens the image so text stays readable" },
    { "type": "header", "content": "Slide 1 · Text" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Hero Banner" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "header", "content": "Slide 1 · Text placement" },
    { "type": "select", "id": "position_v", "label": "Vertical position", "default": "middle", "options": [ { "value": "top", "label": "Top" }, { "value": "middle", "label": "Middle" }, { "value": "bottom", "label": "Bottom" } ] },
    { "type": "select", "id": "position_h", "label": "Horizontal position", "default": "center", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ] },
    { "type": "select", "id": "text_alignment", "label": "Text alignment", "default": "center", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ] },
    { "type": "range", "id": "offset_x", "label": "Nudge horizontally", "min": -100, "max": 100, "step": 5, "unit": "%", "default": 0 },
    { "type": "range", "id": "offset_y", "label": "Nudge vertically", "min": -100, "max": 100, "step": 5, "unit": "%", "default": 0 },
    { "type": "header", "content": "Slide 1 · Text size" },
    { "type": "range", "id": "eyebrow_size", "label": "Eyebrow size", "min": 9, "max": 22, "step": 1, "unit": "px", "default": 11 },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 28, "max": 96, "step": 2, "unit": "px", "default": 56, "info": "Max desktop size; scales down on small screens" },
    { "type": "range", "id": "subheading_size", "label": "Subheading size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 15 },
    { "type": "header", "content": "Slide 1 · Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "info": "Add both a label and a link to show the button" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "button_alignment", "label": "Button placement", "default": "inherit", "options": [ { "value": "inherit", "label": "Same as text" }, { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ] },
    { "type": "header", "content": "Slide 1 · Colors" },
    { "type": "color", "id": "text_color", "label": "Heading & text color", "default": "#4a2c2a" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#a78a5e" },
