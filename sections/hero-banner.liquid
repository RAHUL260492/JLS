        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "url", "id": "button_link", "label": "Button link" },
        { "type": "select", "id": "button_alignment", "label": "Button placement", "default": "inherit", "options": [ { "value": "inherit", "label": "Same as text" }, { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ] },
