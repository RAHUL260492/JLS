{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif

  case section.settings.height
    when 'small'
      assign min_h = '46vh'
    when 'medium'
      assign min_h = '60vh'
    when 'large'
      assign min_h = '78vh'
    when 'full'
      assign min_h = '92vh'
    else
      assign min_h = '60vh'
  endcase

  assign pos_h = section.settings.position_h | default: section.settings.text_alignment | default: 'center'
  assign pos_v = section.settings.position_v | default: 'middle'
  assign txt_align = section.settings.text_alignment | default: pos_h
  assign off_x = section.settings.offset_x | default: 0
  assign off_y = section.settings.offset_y | default: 0
  assign btn_align = section.settings.button_alignment | default: 'inherit'

  case pos_h
    when 'left'
      assign justify = 'flex-start'
    when 'right'
      assign justify = 'flex-end'
    else
      assign justify = 'center'
  endcase

  case pos_v
    when 'top'
      assign align = 'flex-start'
    when 'bottom'
      assign align = 'flex-end'
    else
      assign align = 'center'
  endcase
-%}

<style>
  #hero-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: {{ min_h }};
    display: flex;
    align-items: {{ align }};
    justify-content: {{ justify }};
    text-align: {{ txt_align }};
    overflow: hidden;
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
    {% unless has_image %}background: linear-gradient(135deg, #f5f1ea 0%, #e8e1d4 100%);{% endunless %}
  }
  #hero-{{ section.id }} .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  #hero-{{ section.id }} .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.focal_point | default: 'center center' }};
    display: block;
  }
  #hero-{{ section.id }} .hero__media--mobile { display: none; }
  #hero-{{ section.id }} .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: #000;
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }
  #hero-{{ section.id }} .hero__inner {
    position: relative;
    z-index: 2;
    padding: clamp(48px, 8vw, 96px) 24px;
    max-width: 720px;
    {% if pos_h == 'left' %}margin-left: clamp(24px, 6vw, 96px);{% elsif pos_h == 'right' %}margin-right: clamp(24px, 6vw, 96px);{% endif %}
    {% if pos_v == 'top' %}margin-top: clamp(24px, 6vw, 80px);{% elsif pos_v == 'bottom' %}margin-bottom: clamp(24px, 6vw, 80px);{% endif %}
    {% if off_x != 0 or off_y != 0 %}transform: translate({{ off_x }}%, {{ off_y }}%);{% endif %}
    color: {{ section.settings.text_color | default: '#4a2c2a' }};
  }
  #hero-{{ section.id }} .hero__eyebrow {
    font-family: var(--font-body);
    font-size: {{ section.settings.eyebrow_size | default: 11 }}px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin: 0 0 18px;
    color: {{ section.settings.eyebrow_color | default: section.settings.text_color | default: '#a78a5e' }};
  }
  #hero-{{ section.id }} .hero__title {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 5vw, {{ section.settings.heading_size | default: 56 }}px);
    line-height: 1.1;
    margin: 0 0 14px;
    color: inherit;
  }
  #hero-{{ section.id }} .hero__subtitle {
    font-family: var(--font-body);
    font-size: {{ section.settings.subheading_size | default: 15 }}px;
    line-height: 1.5;
    {% if txt_align == 'center' %}margin: 0 auto;{% elsif txt_align == 'right' %}margin: 0 0 0 auto;{% else %}margin: 0;{% endif %}
    max-width: 540px;
    color: inherit;
    opacity: 0.92;
  }
  #hero-{{ section.id }} .hero__cta {
    {% if btn_align == 'inherit' %}display: inline-block;{% else %}display: block; width: -moz-fit-content; width: fit-content; {% if btn_align == 'left' %}margin-right: auto;{% elsif btn_align == 'right' %}margin-left: auto;{% else %}margin-left: auto; margin-right: auto;{% endif %}{% endif %}
    margin-top: 26px;
    padding: 13px 34px;
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: {{ section.settings.button_text_color | default: '#ffffff' }};
    background: {{ section.settings.button_bg_color | default: '#4a2c2a' }};
    border: 1px solid {{ section.settings.button_bg_color | default: '#4a2c2a' }};
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  #hero-{{ section.id }} .hero__cta:hover { opacity: 0.88; transform: translateY(-1px); }

  /* Placeholder state (no image set) */
  #hero-{{ section.id }} .hero--placeholder::before {
    content: '';
    position: absolute;
    inset: 24px;
    border: 1px dashed rgba(74, 44, 42, 0.25);
    pointer-events: none;
    z-index: 1;
  }
  #hero-{{ section.id }} .hero__dims {
    display: inline-block;
    margin-top: 22px;
    padding: 6px 14px;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: rgba(255,255,255,0.6);
    border: 1px solid var(--color-border-light);
  }

  @media (max-width: 749px) {
    {% if section.settings.image_mobile != blank %}
    #hero-{{ section.id }} .hero__media--desktop { display: none; }
    #hero-{{ section.id }} .hero__media--mobile { display: block; }
    {% endif %}
  }
</style>

<section id="hero-{{ section.id }}" class="hero{% unless has_image %} hero--placeholder{% endunless %}" aria-label="{{ section.settings.heading | default: 'Hero banner' | escape }}">
  {%- if has_image -%}
    <div class="hero__media hero__media--desktop">
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1280 }} 1280w, {{ section.settings.image | image_url: width: 1920 }} 1920w, {{ section.settings.image | image_url: width: 2400 }} 2400w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
        width="1920"
        height="900"
        {% if section.index == 1 %}fetchpriority="high"{% else %}loading="lazy"{% endif %}
      >
    </div>
    {%- if section.settings.image_mobile != blank -%}
      <div class="hero__media hero__media--mobile">
        <img
          src="{{ section.settings.image_mobile | image_url: width: 900 }}"
          srcset="{{ section.settings.image_mobile | image_url: width: 600 }} 600w, {{ section.settings.image_mobile | image_url: width: 900 }} 900w, {{ section.settings.image_mobile | image_url: width: 1200 }} 1200w"
          sizes="100vw"
          alt="{{ section.settings.image_mobile.alt | default: section.settings.heading | escape }}"
          width="900"
          height="1100"
          loading="lazy"
        >
      </div>
    {%- endif -%}
    {%- if section.settings.overlay_opacity > 0 -%}
      <div class="hero__overlay"></div>
    {%- endif -%}
  {%- endif -%}

  <div class="hero__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero__title">{{ section.settings.heading }}</h1>
    {%- elsif has_image == false -%}
      <h1 class="hero__title">Add your campaign imagery here</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero__subtitle">{{ section.settings.subheading }}</p>
    {%- elsif has_image == false -%}
      <p class="hero__subtitle">Replace this placeholder with your hero banner — choose an image and add a headline, then add a button below.</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <a class="hero__cta" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    {%- endif -%}

    {%- unless has_image -%}
      <span class="hero__dims">Recommended: 1920 &times; 900</span>
    {%- endunless -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "Banner image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image",
      "info": "Recommended 1920 × 900. Leave blank to show the placeholder."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image (optional)",
      "info": "Recommended a taller crop, e.g. 900 × 1100"
    },
    {
      "type": "select",
      "id": "focal_point",
      "label": "Image focal point",
      "default": "center center",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "height",
      "label": "Banner height",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full screen" }
      ]
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0,
      "info": "Darkens the image so text stays readable"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Small uppercase label above the heading",
      "default": "Hero Banner"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Text placement",
      "info": "Place the text block anywhere using the 9-point grid, then nudge for precise positioning"
    },
    {
      "type": "select",
      "id": "position_v",
      "label": "Vertical position",
      "default": "middle",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "type": "select",
      "id": "position_h",
      "label": "Horizontal position",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "info": "How the text reads — independent of where the block sits",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "offset_x",
      "label": "Nudge horizontally",
      "min": -100,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "range",
      "id": "offset_y",
      "label": "Nudge vertically",
      "min": -100,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "header",
      "content": "Text size"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow size",
      "min": 9,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "info": "Max desktop size; scales down responsively on smaller screens",
      "min": 28,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "info": "Add both a label and a link to show the button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "Button placement",
      "info": "Where the button sits — independent of the text",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Same as text" },
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading & text color",
      "default": "#4a2c2a"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#a78a5e"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#4a2c2a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
