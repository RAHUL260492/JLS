{%- comment -%}
  Pre-order story: feature mosaic of cards — each card is an image, GIF, or video.

  With no cards added the section renders nothing on the storefront rather than
  an empty band carrying setup instructions. It still renders in the theme
  editor so the merchant can find it and add cards.
{%- endcomment -%}
{%- liquid
  assign po_features_show = false
  if section.blocks.size > 0 or request.design_mode
    assign po_features_show = true
  endif
-%}
{%- if po_features_show -%}
<section class="po-features" style="background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="po-features__heading" style="color:{{ section.settings.caption_color }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="po-features__grid">
    {%- for block in section.blocks -%}
      <figure class="po-features__cell po-features__cell--{{ block.settings.size }}" {{ block.shopify_attributes }}>
        {%- if block.settings.video != blank -%}
          <video class="po-features__media" autoplay muted loop playsinline preload="metadata"
                 {% if block.settings.image != blank %}poster="{{ block.settings.image | image_url: width: 1200 }}"{% endif %}>
            {%- for source in block.settings.video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        {%- elsif block.settings.image != blank -%}
          <img class="po-features__media" src="{{ block.settings.image | image_url: width: 1200 }}"
               srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
               sizes="(min-width: 768px) 50vw, 100vw"
               alt="{{ block.settings.caption | escape }}" loading="lazy">
        {%- else -%}
          <span class="po-features__media po-features__placeholder"></span>
        {%- endif -%}

        <div class="po-features__text" style="color:{{ section.settings.caption_color }};">
          {%- if block.settings.title != blank -%}<p class="po-features__cardtitle">{{ block.settings.title }}</p>{%- endif -%}
          {%- if block.settings.caption != blank -%}<figcaption class="po-features__caption">{{ block.settings.caption }}</figcaption>{%- endif -%}
        </div>
      </figure>
    {%- else -%}
      {%- comment -%} Only ever reached in the theme editor — see the gate above. {%- endcomment -%}
      <p class="po-features__caption" style="color:{{ section.settings.caption_color }};">Add cards in the theme editor — each can be an image, GIF, or video.</p>
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{% stylesheet %}
.po-features { padding: clamp(32px, 6vw, 72px) clamp(16px, 4vw, 56px); }
.po-features__heading { text-align:center; font-family: var(--font-heading, Georgia, serif); font-size: clamp(22px,3vw,34px); margin:0 0 32px; }
.po-features__grid { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: minmax(150px, 1fr); grid-auto-flow: dense; gap: 10px; max-width: 1100px; margin: 0 auto; }
.po-features__cell { position: relative; margin: 0; overflow: hidden; background: rgba(255,255,255,0.04); border-radius: 2px; min-height: 150px; }
.po-features__media { position:absolute; inset:0; width:100%; height:100%; object-fit: cover; display:block; }
.po-features__placeholder { background: linear-gradient(135deg,#3a2a1c,#2a1c12); }
.po-features__cell--tall  { grid-row: span 2; }
.po-features__cell--wide  { grid-column: span 2; }
.po-features__cell--large { grid-column: span 2; grid-row: span 2; }
.po-features__text { position: absolute; left: 16px; bottom: 14px; right: 16px; z-index: 1; text-shadow: 0 1px 6px rgba(0,0,0,0.5); }
.po-features__cardtitle { font-family: var(--font-heading, Georgia, serif); font-size: 17px; margin: 0 0 2px; }
.po-features__caption { font-family: var(--font-body, 'Jost', sans-serif); font-size: 13px; line-height: 1.3; letter-spacing: 0.02em; margin: 0; }
@media (max-width: 767px) {
  .po-features__grid { grid-template-columns: repeat(2, 1fr); }
  .po-features__cell--large, .po-features__cell--wide { grid-column: span 2; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Pre-order: Features",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (optional)" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#2a1c12" },
    { "type": "color", "id": "caption_color", "label": "Text color", "default": "#f3ead9" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image or GIF", "info": "Upload a JPG, PNG, or animated GIF. Also used as the video poster." },
        { "type": "video", "id": "video", "label": "Video (optional)", "info": "Upload a video — it plays muted on loop and overrides the image." },
        { "type": "text", "id": "title", "label": "Card title (optional)" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "select", "id": "size", "label": "Size", "default": "regular",
          "options": [
            { "value": "regular", "label": "Regular" },
            { "value": "wide", "label": "Wide (2 columns)" },
            { "value": "tall", "label": "Tall (2 rows)" },
            { "value": "large", "label": "Large (2x2)" }
          ] }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Pre-order: Features",
      "blocks": [
        { "type": "card", "settings": { "size": "tall", "caption": "A classic silhouette. Works for all." } },
        { "type": "card", "settings": { "size": "regular", "caption": "Mid-rise Cut" } },
        { "type": "card", "settings": { "size": "regular", "caption": "Pre-cut Lengths" } },
        { "type": "card", "settings": { "size": "large", "caption": "Heavy-duty rivets & buttons. YKK zipper." } },
        { "type": "card", "settings": { "size": "regular", "caption": "Reinforced Belt Loops" } },
        { "type": "card", "settings": { "size": "regular", "caption": "Suvin Pockets" } }
      ]
    }
  ]
}
{% endschema %}
