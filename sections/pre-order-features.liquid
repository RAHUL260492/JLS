{%- comment -%} Pre-order story: feature image mosaic with caption callouts {%- endcomment -%}
<section class="po-features" style="background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="po-features__heading" style="color:{{ section.settings.caption_color }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="po-features__grid">
    {%- for block in section.blocks -%}
      <figure class="po-features__cell po-features__cell--{{ block.settings.size }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 1200 }}"
               srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
               sizes="(min-width: 768px) 50vw, 100vw"
               alt="{{ block.settings.caption | escape }}" loading="lazy">
        {%- else -%}
          <span class="po-features__placeholder"></span>
        {%- endif -%}
        {%- if block.settings.caption != blank -%}
          <figcaption class="po-features__caption" style="color:{{ section.settings.caption_color }};">{{ block.settings.caption }}</figcaption>
        {%- endif -%}
      </figure>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
.po-features { padding: clamp(32px, 6vw, 72px) clamp(16px, 4vw, 56px); }
.po-features__heading { text-align:center; font-family: var(--font-heading, Georgia, serif); font-size: clamp(22px,3vw,34px); margin:0 0 32px; }
.po-features__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: minmax(150px, 1fr);
  grid-auto-flow: dense;
  gap: 10px;
  max-width: 1100px;
  margin: 0 auto;
}
.po-features__cell { position: relative; margin: 0; overflow: hidden; background: rgba(255,255,255,0.04); border-radius: 2px; min-height: 150px; }
.po-features__cell img, .po-features__placeholder { position:absolute; inset:0; width:100%; height:100%; object-fit: cover; display:block; }
.po-features__placeholder { background: linear-gradient(135deg,#3a2a1c,#2a1c12); }
.po-features__cell--tall  { grid-row: span 2; }
.po-features__cell--wide  { grid-column: span 2; }
.po-features__cell--large { grid-column: span 2; grid-row: span 2; }
.po-features__caption {
  position: absolute; left: 16px; bottom: 14px; right: 16px;
  font-family: var(--font-body, 'Jost', sans-serif);
  font-size: 13px; line-height: 1.3; letter-spacing: 0.02em;
  text-shadow: 0 1px 6px rgba(0,0,0,0.45); z-index: 1;
}
@media (max-width: 767px) {
  .po-features__grid { grid-template-columns: repeat(2, 1fr); }
  .po-features__cell--large, .po-features__cell--wide { grid-column: span 2; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Pre-order: Features",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (optional)", "default": "" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#2a1c12" },
    { "type": "color", "id": "caption_color", "label": "Caption text", "default": "#f3ead9" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Image tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "select", "id": "size", "label": "Size", "default": "regular",
          "options": [
            { "value": "regular", "label": "Regular" },
            { "value": "wide", "label": "Wide (2 columns)" },
            { "value": "tall", "label": "Tall (2 rows)" },
            { "value": "large", "label": "Large (2x2)" }
          ] }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Pre-order: Features",
      "blocks": [
        { "type": "tile", "settings": { "size": "tall", "caption": "A classic silhouette. Works for all." } },
        { "type": "tile", "settings": { "size": "regular", "caption": "Mid-rise Cut" } },
        { "type": "tile", "settings": { "size": "regular", "caption": "Pre-cut Lengths" } },
        { "type": "tile", "settings": { "size": "large", "caption": "Heavy-duty rivets & buttons. YKK zipper." } },
        { "type": "tile", "settings": { "size": "regular", "caption": "Reinforced Belt Loops" } },
        { "type": "tile", "settings": { "size": "regular", "caption": "Suvin Pockets" } }
      ]
    }
  ]
}
{% endschema %}
