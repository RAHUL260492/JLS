<section class="categories" id="{{ section.settings.section_id | default: 'explore' }}">
  {% if section.settings.heading != blank %}
    <div class="categories__header">
      {% if section.settings.eyebrow != blank %}
        <p class="categories__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="categories__heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="categories__grid">
    {% for block in section.blocks %}
      {%- assign product = block.settings.product -%}
      {%- assign collection = block.settings.collection -%}

      {%- comment -%} Resolve link target: explicit URL > product > collection > # {%- endcomment -%}
      {%- if block.settings.link != blank -%}
        {%- assign tile_url = block.settings.link -%}
      {%- elsif product != blank -%}
        {%- assign tile_url = product.url -%}
      {%- elsif collection != blank -%}
        {%- assign tile_url = collection.url -%}
      {%- else -%}
        {%- assign tile_url = '#' -%}
      {%- endif -%}

      {%- comment -%} Resolve image: explicit override > product featured > collection featured {%- endcomment -%}
      {%- if block.settings.image != blank -%}
        {%- assign tile_image = block.settings.image -%}
      {%- elsif product != blank and product.featured_image -%}
        {%- assign tile_image = product.featured_image -%}
      {%- elsif collection != blank and collection.image -%}
        {%- assign tile_image = collection.image -%}
      {%- else -%}
        {%- assign tile_image = nil -%}
      {%- endif -%}

      {%- comment -%} Resolve label: custom > product title > collection title > fallback {%- endcomment -%}
      {%- if block.settings.label != blank -%}
        {%- assign tile_label = block.settings.label -%}
      {%- elsif product != blank -%}
        {%- assign tile_label = product.title -%}
      {%- elsif collection != blank -%}
        {%- assign tile_label = collection.title -%}
      {%- else -%}
        {%- assign tile_label = 'Add a product' -%}
      {%- endif -%}

      <div class="category-tile{% if tile_image == nil %} category-tile--placeholder{% endif %}" {{ block.shopify_attributes }}>
        <a href="{{ tile_url }}" class="category-tile__image-link">
          <div class="category-tile__image-wrapper{% if tile_image == nil %} category-tile__image-wrapper--placeholder{% endif %}">
            {% if tile_image %}
              <img
                src="{{ tile_image | image_url: width: 800 }}"
                srcset="{{ tile_image | image_url: width: 400 }} 400w, {{ tile_image | image_url: width: 800 }} 800w, {{ tile_image | image_url: width: 1200 }} 1200w"
                sizes="(min-width: 990px) 25vw, 50vw"
                alt="{{ tile_label | escape }}"
                loading="lazy"
                width="800"
                height="1067"
              >
            {% else %}
              <div class="category-tile__placeholder-inner">
                <p class="category-tile__placeholder-eyebrow">Category {{ forloop.index }}</p>
                <p class="category-tile__placeholder-note">Pick a product in theme editor</p>
              </div>
            {% endif %}
          </div>
        </a>
        <div class="category-tile__info">
          <h3 class="category-tile__label">{{ tile_label }}</h3>
          <div class="category-tile__links">
            <a href="{{ tile_url }}">{{ block.settings.cta_text | default: 'Shop Now' }}</a>
          </div>
        </div>
      </div>
    {% else %}
      <p>Add category blocks in the theme editor.</p>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Categories",
  "tag": "section",
  "class": "section-featured-categories",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Small uppercase label above the heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Anchor ID",
      "default": "explore",
      "info": "Used for #anchor links from the nav"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Tile",
      "limit": 8,
      "settings": [
        {
          "type": "header",
          "content": "What this tile points to"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Tile will link to this product and use its featured image by default"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (alternative to product)",
          "info": "Only used if no product is selected"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link (overrides above)"
        },
        {
          "type": "header",
          "content": "Optional overrides"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Tile image override",
          "info": "Leave blank to use the product's featured image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Display label",
          "info": "Leave blank to use the product's title"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA text",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Categories",
      "category": "Image",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
