{%- liquid
  assign prefixes = 'tile1_|tile2_|tile3_|tile4_' | split: '|'
  assign present = 0
  for p in prefixes
    assign ik = p | append: 'image'
    assign hk = p | append: 'heading'
    if forloop.index <= 2
      assign present = present | plus: 1
    elsif section.settings[ik] != blank or section.settings[hk] != blank
      assign present = present | plus: 1
    endif
  endfor
  assign natural = false
  case section.settings.height
    when 'small'
      assign mh = '46vh'
    when 'large'
      assign mh = '72vh'
    when 'natural'
      assign natural = true
    else
      assign mh = '60vh'
  endcase
-%}
<style>
  #split-{{ section.id }} { display: grid; grid-template-columns: repeat({{ present }}, 1fr); gap: 0; margin: 32px 0;{% if natural %} align-items: start;{% endif %} }
  #split-{{ section.id }} .es-tile { position: relative;{% unless natural %} min-height: {{ mh }};{% endunless %} border: 1px solid var(--color-border-light); overflow: hidden; }
  #split-{{ section.id }} .es-tile + .es-tile { border-left: none; }
  @media (max-width: 768px) {
    #split-{{ section.id }} { grid-template-columns: 1fr; }
    {% unless natural %}#split-{{ section.id }} .es-tile { min-height: 46vh; }{% endunless %}
    #split-{{ section.id }} .es-tile + .es-tile { border-left: 1px solid var(--color-border-light); border-top: none; }
  }
</style>
<section id="split-{{ section.id }}" aria-label="Editorial banners">
  {%- for p in prefixes -%}
    {%- assign ik = p | append: 'image' -%}
    {%- assign hk = p | append: 'heading' -%}
    {%- assign show = false -%}
    {%- if forloop.index <= 2 -%}
      {%- assign show = true -%}
    {%- elsif section.settings[ik] != blank or section.settings[hk] != blank -%}
      {%- assign show = true -%}
    {%- endif -%}
    {%- if show -%}
      {%- assign uid = section.id | append: '-' | append: forloop.index -%}
      <div class="es-tile">{% render 'hero-slide', s: section.settings, prefix: p, uid: uid, eager: false, active: true, natural: natural, rec: '1080 × 1320 px' %}</div>
    {%- endif -%}
  {%- endfor -%}
</section>

