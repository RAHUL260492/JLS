<style>
  .section-campaign-banners .cb-banner { position: relative; margin: 32px 0; border-top: 1px solid var(--color-border-light); border-bottom: 1px solid var(--color-border-light); }
</style>
{%- liquid
  assign prefixes = 'banner1_|banner2_|banner3_|banner4_' | split: '|'
-%}
{%- for p in prefixes -%}
  {%- assign ik = p | append: 'image' -%}
  {%- assign hk = p | append: 'heading' -%}
  {%- assign render_this = false -%}
  {%- if forloop.first -%}
    {%- assign render_this = true -%}
  {%- elsif section.settings[ik] != blank or section.settings[hk] != blank -%}
    {%- assign render_this = true -%}
  {%- endif -%}
  {%- if render_this -%}
    {%- assign hkey = p | append: 'height' -%}
    {%- assign h = section.settings[hkey] | default: 'medium' -%}
    {%- assign natural = false -%}
    {%- case h -%}
      {%- when 'small' -%}{%- assign mh = '36vh' -%}
      {%- when 'large' -%}{%- assign mh = '60vh' -%}
      {%- when 'natural' -%}{%- assign mh = '0' -%}{%- assign natural = true -%}
      {%- else -%}{%- assign mh = '44vh' -%}
    {%- endcase -%}
    {%- assign uid = section.id | append: '-' | append: forloop.index -%}
    <div class="cb-banner" style="{% if natural %}min-height: 0;{% else %}min-height: {{ mh }};{% endif %}">
      {% render 'hero-slide', s: section.settings, prefix: p, uid: uid, eager: false, active: true, natural: natural, rec: '1920 × 860 px' %}
    </div>
  {%- endif -%}
{%- endfor -%}

