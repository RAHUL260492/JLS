{%- comment -%}
  Featured Items — category-aware.

  Each "Category rule" block maps a collection to its own heading + product set.
  On a product page the first block whose collection contains the current product
  wins, so a Men's Shoes & Accessories product and a Women's Home product each get
  their own carousel. Anything that matches no block falls back to the section
  defaults below, which is also what non-product templates get.

  Per block, products resolve as: hand-picked list -> that collection's own
  products. Leaving the list empty means the carousel auto-fills as products are
  added to the collection.
{%- endcomment -%}

{%- comment -%} Handles of every collection the current product belongs to, pipe-delimited. {%- endcomment -%}
{%- capture feat_in_collections -%}|{% for c in product.collections %}{{ c.handle }}|{% endfor %}{%- endcapture -%}

{%- assign feat_match = -1 -%}
{%- for block in section.blocks -%}
  {%- unless feat_match >= 0 -%}
    {%- if block.settings.collection != blank -%}
      {%- assign feat_needle = '|' | append: block.settings.collection.handle | append: '|' -%}
      {%- if feat_in_collections contains feat_needle -%}
        {%- assign feat_match = forloop.index0 -%}
      {%- endif -%}
    {%- endif -%}
  {%- endunless -%}
{%- endfor -%}

{%- assign feat_heading = section.settings.heading -%}
{%- assign feat_resolved = false -%}

{%- if feat_match >= 0 -%}
  {%- assign feat_rule = section.blocks[feat_match] -%}
  {%- if feat_rule.settings.heading != blank -%}
    {%- assign feat_heading = feat_rule.settings.heading -%}
  {%- endif -%}
  {%- if feat_rule.settings.products.size > 0 -%}
    {%- assign feat = feat_rule.settings.products -%}
    {%- assign feat_resolved = true -%}
  {%- elsif feat_rule.settings.collection.products_count > 0 -%}
    {%- assign feat = feat_rule.settings.collection.products -%}
    {%- assign feat_resolved = true -%}
  {%- endif -%}
{%- endif -%}

{%- unless feat_resolved -%}
  {%- if section.settings.products.size > 0 -%}
    {%- assign feat = section.settings.products -%}
  {%- else -%}
    {%- assign feat = collections.all.products -%}
  {%- endif -%}
{%- endunless -%}

<section class="featured-items">
  {%- if feat_heading != blank -%}
    <h2 class="featured-items__title">{{ feat_heading }}</h2>
  {%- endif -%}

  <div class="featured-items__viewport">
    <div class="featured-items__track" style="--feat-speed: {{ section.settings.speed }}s;">
      {%- for product in feat limit: section.settings.max -%}
        {% render 'featured-card', product: product %}
      {%- endfor -%}
      {%- comment -%} Duplicate set for a seamless right-to-left loop {%- endcomment -%}
      {%- for product in feat limit: section.settings.max -%}
        {% render 'featured-card', product: product, dup: true %}
      {%- else -%}
        <p class="featured-items__empty">Add products in the theme editor.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.featured-items { padding: clamp(48px, 7vw, 80px) 0; overflow: hidden; }
.featured-items__title {
  text-align: center;
  font-family: var(--font-heading, 'Cormorant Garamond', Georgia, serif);
  font-size: clamp(24px, 3vw, 34px);
  margin: 0 0 36px;
}
.featured-items__viewport { width: 100%; overflow: hidden; }
.featured-items__track {
  display: flex;
  gap: 24px;
  width: max-content;
  padding: 0 24px;
  animation: featured-scroll var(--feat-speed, 40s) linear infinite;
}
.featured-items__viewport:hover .featured-items__track { animation-play-state: paused; }
@keyframes featured-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
@media (prefers-reduced-motion: reduce) {
  .featured-items__track { animation: none; }
  .featured-items__viewport { overflow-x: auto; }
}
.featured-card { flex: 0 0 auto; width: 220px; text-decoration: none; color: var(--color-text-primary, #1a1a1a); }
.featured-card__img { background: #f5f4f0; aspect-ratio: 3 / 4; overflow: hidden; }
.featured-card__img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
.featured-card:hover .featured-card__img img { transform: scale(1.03); }
.featured-card__name { font-family: var(--font-body, 'Jost', sans-serif); font-size: 14px; letter-spacing: 0.02em; margin: 10px 0 2px; }
.featured-card__price { font-family: var(--font-body, 'Jost', sans-serif); font-size: 14px; margin: 0; }
.featured-card__price .price--sale { color: var(--color-sale-green, #177245); }
.featured-card__price s { color: #999; }
.featured-items__empty { text-align: center; color: #888; font-family: var(--font-body, sans-serif); width: 100%; }
@media (max-width: 749px) { .featured-card { width: 160px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Items",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Default (used when no category rule matches)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Items" },
    { "type": "product_list", "id": "products", "label": "Products", "limit": 24, "info": "Pick the products to feature. If none are selected, newest products are shown." },
    { "type": "header", "content": "Carousel" },
    { "type": "range", "id": "max", "label": "Max products to show", "min": 4, "max": 24, "step": 1, "default": 12 },
    { "type": "range", "id": "speed", "label": "Scroll duration (seconds, lower = faster)", "min": 15, "max": 90, "step": 5, "default": 45 }
  ],
  "blocks": [
    {
      "type": "rule",
      "name": "Category rule",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Show this set when the product is in", "info": "Rules are checked top to bottom and the first match wins, so put the most specific collection first." },
        { "type": "text", "id": "heading", "label": "Heading", "info": "Leave blank to use the default heading." },
        { "type": "product_list", "id": "products", "label": "Products to feature", "limit": 24, "info": "Leave empty to automatically show products from the collection above." }
      ]
    }
  ],
  "presets": [ { "name": "Featured Items" } ]
}
{% endschema %}
