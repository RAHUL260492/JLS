{% comment %}
  product.liquid — product detail page (PDP)
  Renders for any URL like /products/<handle>.
  Layout: stacked image gallery on the left, sticky info column on the right
  (vendor, title, price, variant selector, add-to-cart, details accordion).
  Below: "You May Also Like" related products from the same collection.
{% endcomment %}

<style>
  /* ---------- PDP layout ---------- */
  .pdp {
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 24px 80px;
  }
  .pdp__breadcrumb {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 24px;
  }
  .pdp__breadcrumb a { color: #888; text-decoration: none; }
  .pdp__breadcrumb a:hover { color: #1a1a1a; }
  .pdp__breadcrumb span.sep { margin: 0 8px; }

  .pdp__layout {
    display: grid;
    grid-template-columns: minmax(0, 600px) 380px;
    gap: 48px;
    align-items: start;
    justify-content: space-between;
  }
  @media (max-width: 960px) {
    .pdp__layout { grid-template-columns: 1fr; gap: 24px; }
  }

  /* ---------- Image gallery (left) ---------- */
  .pdp__gallery {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pdp__gallery-item {
    background: #f5f4f0;
    overflow: hidden;
  }
  .pdp__gallery-item img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ---------- Sticky info column (right) ---------- */
  .pdp__info {
    position: sticky;
    top: 24px;
    align-self: start;
  }
  .pdp__info-inner {
    padding: 0;
  }
  .pdp__vendor {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 8px;
  }
  .pdp__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 28px;
    letter-spacing: 0.02em;
    line-height: 1.2;
    margin: 0 0 12px;
    color: #1a1a1a;
  }
  .pdp__price {
    font-family: 'Jost', sans-serif;
    font-size: 18px;
    letter-spacing: 0.04em;
    color: #1a1a1a;
    margin-bottom: 24px;
  }
  /* currency symbol comes from the store money format (format="money") */
  /* Sale pricing: shown automatically whenever compare-at price > price */
  .pdp__price-now { color: var(--color-sale-green, #177245); }
  .pdp__price-was {
    color: #999999;
    margin-left: 8px;
    text-decoration-thickness: 1px;
  }
  .pdp__variant-selector { margin: 24px 0; }
  .pdp__variant-selector shopify-variant-selector {
    display: block;
    font-family: 'Jost', sans-serif;
  }
  .pdp__add-to-cart {
    width: 100%;
    padding: 16px 24px;
    background: #1a1a1a;
    color: #fff;
    border: 1px solid #1a1a1a;
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    margin-bottom: 12px;
  }
  .pdp__add-to-cart:hover {
    background: #fff;
    color: #1a1a1a;
  }
  .pdp__add-to-cart[disabled],
  .pdp__add-to-cart[disabled]:hover {
    background: #ccc;
    color: #fff;
    border-color: #ccc;
    cursor: not-allowed;
  }
  .pdp__wishlist {
    width: 100%;
    padding: 14px 24px;
    background: #fff;
    color: #1a1a1a;
    border: 1px solid #1a1a1a;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    cursor: pointer;
    margin-bottom: 24px;
  }

  /* ---------- Accordion details ---------- */
  .pdp__details details {
    border-top: 1px solid #e8e5dd;
    padding: 16px 0;
  }
  .pdp__details details:last-of-type { border-bottom: 1px solid #e8e5dd; }
  .pdp__details summary {
    cursor: pointer;
    list-style: none;
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #1a1a1a;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .pdp__details summary::-webkit-details-marker { display: none; }
  .pdp__details summary::after {
    content: '+';
    font-size: 16px;
    transition: transform 0.2s;
  }
  .pdp__details details[open] summary::after { content: '−'; }
  .pdp__details-body {
    padding: 16px 0 4px;
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    line-height: 1.7;
    color: #555;
  }
  .pdp__details-body p { margin: 0 0 8px; }

  /* ---------- "You may also like" ---------- */
  .pdp__related {
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid #e8e5dd;
  }
  .pdp__related-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 24px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 32px;
    color: #1a1a1a;
  }
  .pdp__related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 900px) {
    .pdp__related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .pdp__related-card {
    text-decoration: none;
    color: inherit;
  }
  .pdp__related-card-image {
    aspect-ratio: 4 / 5;
    background: #f5f4f0;
    overflow: hidden;
    margin-bottom: 10px;
  }
  .pdp__related-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .pdp__related-card:hover .pdp__related-card-image img { transform: scale(1.03); }
  .pdp__related-card-name {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    letter-spacing: 0.05em;
    color: #1a1a1a;
    margin: 0 0 4px;
  }
  .pdp__related-card-price {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    color: #888;
    margin: 0;
  }
</style>

<main id="main" class="pdp">

  <!-- Breadcrumb -->
  <nav class="pdp__breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="sep">/</span>
    {% if collection %}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span class="sep">/</span>
    {% endif %}
    <span>{{ product.title }}</span>
  </nav>

  <shopify-context type="product" handle="{{ product.handle }}">
  <template>
  <div class="pdp__layout">

    <!-- LEFT: Image gallery. The main image reacts to the selected variant (colour swatch). -->
    <div class="pdp__gallery">
      {%- assign has_color_variants = false -%}
      {%- for opt in product.options_with_values -%}
        {%- assign opt_name = opt.name | downcase -%}
        {%- if opt_name contains 'color' or opt_name contains 'colour' -%}
          {%- if opt.values.size > 1 -%}{%- assign has_color_variants = true -%}{%- endif -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_color_variants -%}
        {%- comment -%} Colour variants: tag each photo with the colour(s) named in its Alt text (and any variant it's assigned to); the script shows only the selected colour's photos. Put the colour word in each photo's Alt text in Admin. {%- endcomment -%}
        {%- assign color_idx = 0 -%}
        {%- assign color_values = '' -%}
        {%- for opt in product.options_with_values -%}
          {%- assign on = opt.name | downcase -%}
          {%- if on contains 'color' or on contains 'colour' -%}
            {%- assign color_idx = forloop.index0 -%}
            {%- for val in opt.values -%}{%- assign color_values = color_values | append: '~' | append: val.name | downcase | strip -%}{%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign color_value_list = color_values | split: '~' -%}
        <span class="pdp__selected-variant" data-selected-variant hidden><shopify-data query="product.selectedOrFirstAvailableVariant.title"></shopify-data></span>
        {%- for image in product.images -%}
          {%- assign img_colors = '' -%}
          {%- assign alt_l = image.alt | downcase -%}
          {%- for cval in color_value_list -%}
            {%- if cval != blank and alt_l contains cval -%}{%- assign img_colors = img_colors | append: '|' | append: cval | append: '|' -%}{%- endif -%}
          {%- endfor -%}
          {%- for v in image.variants -%}
            {%- assign cv = v.options[color_idx] | downcase | strip -%}
            {%- unless img_colors contains cv -%}{%- assign img_colors = img_colors | append: '|' | append: cv | append: '|' -%}{%- endunless -%}
          {%- endfor -%}
          <div class="pdp__gallery-item" data-colors="{{ img_colors }}">
            <img src="{{ image | image_url: width: 1400 }}"
                 srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1400 }} 1400w"
                 sizes="(max-width: 960px) 100vw, 60vw"
                 alt="{{ image.alt | default: product.title | escape }}"
                 width="{{ image.width }}" height="{{ image.height }}" decoding="async" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"{% if forloop.first %} fetchpriority="high"{% endif %}>
          </div>
        {%- endfor -%}
      {%- elsif product.images.size > 0 -%}
        {%- for image in product.images -%}
          <div class="pdp__gallery-item">
            <img src="{{ image | image_url: width: 1400 }}"
                 srcset="{{ image | image_url: width: 600 }} 600w,
                         {{ image | image_url: width: 900 }} 900w,
                         {{ image | image_url: width: 1400 }} 1400w"
                 sizes="(max-width: 960px) 100vw, 60vw"
                 alt="{{ image.alt | default: product.title | escape }}"
                 width="{{ image.width }}"
                 height="{{ image.height }}"
                 decoding="async"
                 loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"{% if forloop.first %} fetchpriority="high"{% endif %}>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="pdp__gallery-item"><img src="{{ 'no-image.png' | asset_url }}" alt="{{ product.title | escape }}"></div>
      {%- endif -%}
    </div>

    <!-- RIGHT: Sticky product info (web components for live variant data) -->
    <aside class="pdp__info">
      <div class="pdp__info-inner">

        <h1 class="pdp__title"><shopify-data query="product.title"></shopify-data></h1>
        {%- assign pdp_variant = product.selected_or_first_available_variant -%}
        <div class="pdp__price">
          {%- if pdp_variant.compare_at_price > pdp_variant.price -%}
            <shopify-money class="pdp__price-now" format="money" query="product.selectedOrFirstAvailableVariant.price"></shopify-money>
            <s class="pdp__price-was"><shopify-money format="money" query="product.selectedOrFirstAvailableVariant.compareAtPrice"></shopify-money></s>
          {%- else -%}
            <shopify-money format="money" query="product.selectedOrFirstAvailableVariant.price"></shopify-money>
          {%- endif -%}
        </div>

        {%- comment -%} Cross-product colour swatches: link to the sibling colour products. {%- endcomment -%}
        {%- assign color_siblings = product.metafields.custom.color_group.value -%}
        {%- if color_siblings and color_siblings.size > 1 -%}
          <div class="pdp__color-group">
            <p class="pdp__color-group-label">Colour</p>
            <div class="pdp__color-group-swatches">
              {%- for sib in color_siblings -%}
                {%- assign sib_hex = sib.metafields.custom.swatch.value | default: '#cccccc' -%}
                {%- assign sib_color = sib.title -%}
                {%- for o in sib.options_with_values -%}
                  {%- assign on2 = o.name | downcase -%}
                  {%- if on2 contains 'color' or on2 contains 'colour' -%}{%- assign sib_color = o.values.first.name -%}{%- endif -%}
                {%- endfor -%}
                <a href="{{ sib.url }}" class="pdp__color-group-swatch{% if sib.id == product.id %} is-active{% endif %}" style="--sw:{{ sib_hex }}" title="{{ sib_color | escape }}" aria-label="{{ sib_color | escape }}"></a>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} If colour has a single value it's redundant (the swatch row handles colour) — show only the size option to avoid an inconsistent colour control. {%- endcomment -%}
        {%- assign size_option_name = '' -%}
        {%- assign color_value_count = 0 -%}
        {%- for opt in product.options_with_values -%}
          {%- assign on3 = opt.name | downcase -%}
          {%- if on3 contains 'color' or on3 contains 'colour' -%}
            {%- assign color_value_count = opt.values.size -%}
          {%- elsif size_option_name == '' -%}
            {%- assign size_option_name = opt.name -%}
          {%- endif -%}
        {%- endfor -%}
        <div class="pdp__variant-selector">
          {%- if color_value_count == 1 and size_option_name != blank -%}
            <shopify-variant-selector visible-option="{{ size_option_name }}"></shopify-variant-selector>
          {%- else -%}
            <shopify-variant-selector></shopify-variant-selector>
          {%- endif -%}
        </div>

        <span class="pdp__vtitle" data-variant-title hidden><shopify-data query="product.selectedOrFirstAvailableVariant.title"></shopify-data></span>
        <p class="pdp__custom-note" data-custom-note hidden>✦ Our team will reach out to you to take your measurements for this customised outfit.</p>

        <button
          class="pdp__add-to-cart"
          onclick="document.getElementById('cart').addLine(event); document.getElementById('cart').showModal();"
          shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale">
          Add to Bag
        </button>

        <button class="pdp__wishlist" type="button" aria-label="Add to wishlist"
          data-wishlist-toggle
          data-handle="{{ product.handle }}"
          data-title="{{ product.title | escape }}"
          data-url="{{ product.url }}"
          data-image="{{ product.featured_image | image_url: width: 400 }}"
          data-price="{{ product.price | money }}">
          <span class="pdp__wishlist-icon">♡</span> &nbsp; <span class="pdp__wishlist-label">Add to Wishlist</span>
        </button>

        <!-- Accordion details (server-rendered from product) -->
        <div class="pdp__details">
          <details>
            <summary>Product Details</summary>
            <div class="pdp__details-body">
              {% if product.description != blank %}
                {{ product.description }}
              {% else %}
                <p>Premium, considered essentials from Just Adulting Club. Crafted from carefully selected fabrics and finished with quiet, refined detailing.</p>
              {% endif %}
            </div>
          </details>

          <details>
            <summary>Size &amp; Fit</summary>
            <div class="pdp__details-body">
              {% if product.metafields.custom.size_fit != blank %}{{ product.metafields.custom.size_fit }}{% else %}{{ settings.pdp_size_fit }}{% endif %}
            </div>
          </details>

          <details>
            <summary>Materials &amp; Care</summary>
            <div class="pdp__details-body">
              {% if product.metafields.custom.materials != blank %}{{ product.metafields.custom.materials }}{% else %}{{ settings.pdp_materials_care }}{% endif %}
            </div>
          </details>

          <details>
            <summary>Shipping, Returns &amp; Exchange</summary>
            <div class="pdp__details-body">
              {% if product.metafields.custom.shipping_returns != blank %}{{ product.metafields.custom.shipping_returns }}{% elsif settings.pdp_shipping != blank %}{{ settings.pdp_shipping }}{% else %}{% render 'shipping-returns' %}{% endif %}
            </div>
          </details>
        </div>

      </div>
    </aside>

  </div>
  </template>
  </shopify-context>

</main>

<!-- ===== Pre-order editorial story (all blocks editable in Theme Customizer) ===== -->
{% section 'pre-order-quote' %}
{% section 'pre-order-features' %}
{% section 'pre-order-hero' %}
{% section 'pre-order-philosophy' %}
{% section 'pre-order-flatlay' %}
