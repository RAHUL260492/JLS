
    
    <!-- Category Banner (editable section — image + text + button, manage in Shopify Theme Customizer) -->
    {% section 'category-banner-women' %}

    <!-- CATEGORY TITLE & TABS -->
    <header class="category-header">
      <h1 class="category-title">SHOP WOMEN</h1>
      <div class="subcategory-tabs">
        <a href="#" class="subcategory-tab">CASUAL</a>
        <a href="#" class="subcategory-tab">SHIRTS</a>
        <a href="#" class="subcategory-tab">POLOS</a>
        <a href="#" class="subcategory-tab is-active">PANTS</a>
        <a href="#" class="subcategory-tab">OUTERWEAR</a>
        <a href="#" class="subcategory-tab">SWIM</a>
      </div>
    </header>

    <!-- FILTER & SORT CONTROLS -->
    <section class="filter-bar">
      <div class="filter-group">
        <div class="filter-dropdown">Filter +</div>
      </div>
      <div class="filter-group">
        <div class="filter-dropdown">Sort By: Recommended <span style="font-size:8px; margin-left:4px;">&#9660;</span></div>
      </div>
    </section>

    <!-- PRODUCT GRID (Shopify List Context) -->
    <section class="product-grid-section">
      <div class="product-grid" id="categoryProductGrid">
        <shopify-context type="collection" handle="women">
          <template>
            <shopify-list-context id="productGridContext" type="product" query="collection.products" first="18" style="display: contents;">
              <template>
                <article class="product-card" style="position:relative;">
                  <a shopify-attr--href="product.onlineStoreUrl" class="product-card__image-link">
                    <div class="product-card__image-wrapper">
                      <shopify-media query="product.selectedOrFirstAvailableVariant.image"></shopify-media>
                    </div>
                  </a>
                  <div class="product-card__info">
                    <a shopify-attr--href="product.onlineStoreUrl" class="product-card__name">
                      <shopify-data query="product.title"></shopify-data>
                    </a>
                    <p class="product-card__price">
                      <shopify-money format="money" query="product.selectedOrFirstAvailableVariant.price"></shopify-money>
                    </p>
                    <p class="product-card__promo">
                      <shopify-data query="product.vendor"></shopify-data>
                    </p>
                  </div>
                </article>
              </template>
            </shopify-list-context>
          </template>
        </shopify-context>
      </div>
    </section>

    <!-- PAGINATION BAR -->
    <section class="pagination-section">
      <div class="pagination-section__inner">
        <button class="pagination-load-btn" id="loadMoreBtn">Load more items</button>
        <p class="pagination-range">1-3 of 3 items</p>
      </div>
    </section>
    
    <!-- SEO CONTENT BLOCK -->
    <section class="seo-content-section">
      <div class="seo-content-section__inner">
        <p class="seo-content__intro">Discover our signature collection of men's apparel, thoughtfully designed for modern versatility. From sharply tailored essentials to relaxed off-duty staples, every piece is crafted to elevate your daily wardrobe with effortless confidence and enduring quality.</p>
        
        <h3 class="seo-content__heading">The Three-Piece Suit</h3>
        <p class="seo-content__body">Make a definitive statement with our <a href="#">Italian wool suiting</a>. Ideal for weddings, formal galas, or high-stakes meetings, the tailored fit ensures a powerful silhouette. Pair with our <a href="#">premium dress shirts</a> and silk ties for an uncompromisingly polished look.</p>
        
        <h3 class="seo-content__heading">Polished Appeal</h3>
        <p class="seo-content__body">For settings that call for refined nuance, explore our <a href="#">cashmere blend knits</a> and smart-casual trousers. Whether transitioning from office hours to evening engagements, these pieces offer the perfect balance of comfort and sharp, contemporary style.</p>
      </div>
    </section>
  