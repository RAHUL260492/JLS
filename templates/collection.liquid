{% comment %}
  Collection template — Just Adulting Club
  Renders for any URL like /collections/pants, /collections/shirts, etc.
  - Title and product list are driven dynamically by the collection in the URL.
  - Subcategory tabs are the 5 fixed categories: Pants, Shirts, Shorts, Socks, T-shirts.
{% endcomment %}

    <!-- Category Banner (editable section — image + text + button, manage in Shopify Theme Customizer) -->
    {% section 'category-banner-collection' %}

    <!-- CATEGORY TITLE & TABS (context-aware: men's / women's / generic) -->
    {%- liquid
      assign h = collection.handle
      assign tabset = 'default'
      if h == 'men' or h contains 'mens-'
        assign tabset = 'men'
      elsif h == 'women' or h contains 'womens-'
        assign tabset = 'women'
      endif
      case tabset
        when 'men'
          assign tabs = 'mens-casual-shirts|Casual Shirts,mens-tshirts|T-Shirts,mens-polos|Polos,mens-chinos-joggers-pants|Pants,mens-jeans|Jeans,mens-shorts|Shorts,mens-sweaters|Sweaters,mens-coats-jackets|Outerwear,mens-dress-shirts|Dress Shirts,mens-blazers-suits|Blazers,mens-blazers-suits|Suits'
        when 'women'
          assign tabs = 'womens-dresses-jumpsuits-tops-shirts|Dresses & Tops,womens-tshirts-tanks|T-Shirts & Tanks,womens-pants|Pants,womens-denims|Denims,womens-shorts|Shorts,womens-skirts|Skirts,womens-sweaters|Sweaters,womens-coats-jackets|Outerwear,womens-blazers-suits|Blazers,womens-swimwear|Swimwear'
        else
          assign tabs = 'pants|Pants,shirts|Shirts,shorts|Shorts,socks|Socks,tshirts|T-Shirts'
      endcase
    -%}
    <header class="category-header">
      <h1 class="category-title">{{ collection.title | default: 'SHOP ALL APPAREL' | upcase }}</h1>
      <div class="subcategory-tabs">
        {%- assign tab_list = tabs | split: ',' -%}
        {%- for tab in tab_list -%}
          {%- assign parts = tab | split: '|' -%}
          <a href="/collections/{{ parts[0] }}" class="subcategory-tab{% if collection.handle == parts[0] %} is-active{% endif %}">{{ parts[1] }}</a>
        {%- endfor -%}
      </div>
    </header>

    {%- paginate collection.products by 24 -%}
    <!-- FILTER & SORT TOOLBAR (functional, native faceted filters) -->
    <form method="get" class="collection-toolbar" id="CollectionFilterForm">
      <div class="collection-toolbar__row">
        <div class="collection-filters">
          {%- for filter in collection.filters -%}
            <div class="filter-group" data-filter-group>
              <button type="button" class="filter-pill" aria-expanded="false" data-filter-pill>{{ filter.label }}{% if filter.active_values.size > 0 %} <span class="filter-pill__count">{{ filter.active_values.size }}</span>{% endif %}</button>
              <div class="filter-panel" hidden>
                {%- case filter.type -%}
                  {%- when 'price_range' -%}
                    <div class="filter-price">
                      <label>Min <input type="number" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}" min="0" max="{{ filter.range_max | money_without_currency | replace: ',', '' }}" inputmode="decimal"></label>
                      <label>Max <input type="number" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}" min="0" max="{{ filter.range_max | money_without_currency | replace: ',', '' }}" inputmode="decimal"></label>
                      <button type="submit" class="filter-apply">Apply</button>
                    </div>
                  {%- else -%}
                    <ul class="filter-options">
                      {%- for value in filter.values -%}
                        <li><label class="filter-option{% if value.count == 0 and value.active == false %} is-muted{% endif %}">
                          <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} data-filter-input>
                          <span class="filter-option__label">{{ value.label }}</span>
                          <span class="filter-option__count">{{ value.count }}</span>
                        </label></li>
                      {%- endfor -%}
                    </ul>
                {%- endcase -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
        <div class="collection-sort">
          <label class="visually-hidden" for="SortBy">Sort by</label>
          <select id="SortBy" name="sort_by" class="filter-sort" data-auto-submit>
            {%- assign sort_default = collection.sort_by | default: collection.default_sort_by -%}
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == sort_default %}selected{% endif %}>Sort: {{ option.name }}</option>
            {%- endfor -%}
          </select>
        </div>
      </div>
      <div class="collection-toolbar__meta">
        <p class="results-count">{{ collection.products_count }} Result{% if collection.products_count != 1 %}s{% endif %}</p>
        {%- assign has_active = false -%}
        {%- for filter in collection.filters -%}{%- if filter.active_values.size > 0 or filter.min_value.value or filter.max_value.value -%}{%- assign has_active = true -%}{%- endif -%}{%- endfor -%}
        {%- if has_active -%}
          <div class="active-filters">
            {%- for filter in collection.filters -%}
              {%- for value in filter.active_values -%}
                <a class="active-filter" href="{{ value.url_to_remove }}">{{ value.label }} &times;</a>
              {%- endfor -%}
              {%- if filter.type == 'price_range' -%}
                {%- if filter.min_value.value or filter.max_value.value -%}
                  <a class="active-filter" href="{{ filter.url_to_remove }}">{{ filter.label }} &times;</a>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            <a class="active-filter active-filter--clear" href="{{ collection.url }}{% if collection.sort_by %}?sort_by={{ collection.sort_by }}{% endif %}">Clear all</a>
          </div>
        {%- endif -%}
      </div>
    </form>

    <!-- PRODUCT GRID (server-rendered) -->
    <section class="product-grid-section">
      <div class="product-grid" id="categoryProductGrid">
        {%- for product in collection.products -%}
          <article class="product-card">
            <a href="{{ product.url }}" class="product-card__image-link">
              <div class="product-card__image-wrapper">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 800 }}"
                       srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
                       sizes="(min-width: 990px) 25vw, 50vw"
                       alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy" width="800" height="1067">
                {%- endif -%}
              </div>
            </a>
            <div class="product-card__info">
              <a href="{{ product.url }}" class="product-card__name">{{ product.title }}</a>
              <p class="product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="price--sale">{{ product.price | money }}</span> <s>{{ product.compare_at_price | money }}</s>
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </p>
              <p class="product-card__promo">{{ product.vendor }}</p>
            </div>
          </article>
        {%- else -%}
          <p class="collection-empty">No products match these filters. <a href="{{ collection.url }}">Clear filters</a></p>
        {%- endfor -%}
      </div>
    </section>

    <!-- PAGINATION -->
    {%- if paginate.pages > 1 -%}
      <nav class="pagination-section" role="navigation" aria-label="Pagination">
        <div class="pagination-section__inner pagination-links">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="pagination-link">&lsaquo;</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}" class="pagination-link">{{ part.title }}</a>
            {%- else -%}<span class="pagination-link{% if part.title == paginate.current_page %} is-current{% endif %}">{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="pagination-link">&rsaquo;</a>{%- endif -%}
        </div>
      </nav>
    {%- endif -%}
    {%- endpaginate -%}

    <!-- RELATED LINKS ROW -->
    <section class="related-links-section">
      <div class="related-links-section__inner">
        <h4 class="related-links__heading">Also Explore</h4>
        <div class="related-links__list">
          <a href="/collections/pants"   class="related-link">Pants</a>
          <span class="related-link-separator">|</span>
          <a href="/collections/shirts"  class="related-link">Shirts</a>
          <span class="related-link-separator">|</span>
          <a href="/collections/shorts"  class="related-link">Shorts</a>
          <span class="related-link-separator">|</span>
          <a href="/collections/socks"   class="related-link">Socks</a>
          <span class="related-link-separator">|</span>
          <a href="/collections/tshirts" class="related-link">T-Shirts</a>
        </div>
      </div>
    </section>

    <!-- SEO CONTENT BLOCK — driven by collection.description if set in Shopify admin -->
    <section class="seo-content-section">
      <div class="seo-content-section__inner">
        {% if collection.description != blank %}
          {{ collection.description }}
        {% else %}
          {% case collection.handle %}
            {% when 'pants' %}
              <p class="seo-content__intro">From tailored trousers to relaxed-fit chinos, our pants are cut from premium fabrics and designed to move with you. Refined silhouettes, considered details, built for every day.</p>
              <h3 class="seo-content__heading">Tailored Trousers</h3>
              <p class="seo-content__body">Italian wool and crisp wool blends in classic and slim fits. Built to hold a sharp line for the office, weddings, and evenings out.</p>
              <h3 class="seo-content__heading">Everyday Chinos</h3>
              <p class="seo-content__body">Stretch-cotton chinos in seasonless tones — sand, olive, navy, charcoal. Tapered through the leg, structured at the waist.</p>

            {% when 'shirts' %}
              <p class="seo-content__intro">Considered shirting for every part of the week. Long-staple cotton, breathable linen, and Italian-milled twill, finished with mother-of-pearl buttons and clean, contemporary cuts.</p>
              <h3 class="seo-content__heading">The Linen Shirt</h3>
              <p class="seo-content__body">Cool, lightweight, garment-washed for an instantly broken-in feel. The defining warm-weather essential.</p>
              <h3 class="seo-content__heading">The Dress Shirt</h3>
              <p class="seo-content__body">Crisp poplin and oxford weaves cut for a clean line through the body. Versatile enough for the boardroom, refined enough for a dinner jacket.</p>

            {% when 'shorts' %}
              <p class="seo-content__intro">From tailored linen to easy drawstring fits, shorts engineered for warmer days. Cut above the knee, fully lined where it matters.</p>
              <h3 class="seo-content__heading">Tailored Shorts</h3>
              <p class="seo-content__body">Pleated, knee-length and finished with a clean hem — the warm-weather alternative to a suit trouser.</p>
              <h3 class="seo-content__heading">Casual &amp; Swim</h3>
              <p class="seo-content__body">Quick-drying swim shorts and drawstring linen styles in a refined palette. Built for the beach, finished well enough for the bar afterwards.</p>

            {% when 'socks' %}
              <p class="seo-content__intro">Long-staple cotton, seamless toes, and odour-eliminating fibres. Engineered for long days on your feet.</p>
              <h3 class="seo-content__heading">Sentinel — Advanced No-Smell Tech</h3>
              <p class="seo-content__body">Precision-built to act instantly — eradicating odour-causing bacteria in seconds, while you carry on. Seamless toe, extra cushioning, breathable fabric.</p>
              <h3 class="seo-content__heading">3x Softer Than Cotton</h3>
              <p class="seo-content__body">Our long-staple cotton makes our socks softer and longer-lasting than the regular cotton equivalent.</p>

            {% when 'tshirts' %}
              <p class="seo-content__intro">Heavyweight cotton, considered cuts and a quiet palette. Crew-necks, V-necks, and relaxed pocket tees built to layer and built to last.</p>
              <h3 class="seo-content__heading">The Heavyweight Crew</h3>
              <p class="seo-content__body">Dense, dropped-shoulder jersey in a clean, modern silhouette. Holds its shape in the wash, gets better with wear.</p>
              <h3 class="seo-content__heading">Refined Basics</h3>
              <p class="seo-content__body">Slim-fit cotton tees in a palette of cream, sand, navy and charcoal.</p>

            {% else %}
              <p class="seo-content__intro">Discover our signature collection of premium apparel, thoughtfully designed for modern versatility. Every piece is crafted to elevate your daily wardrobe with effortless confidence and enduring quality.</p>
          {% endcase %}
        {% endif %}
      </div>
    </section>
