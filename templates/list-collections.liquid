{% comment %}
  list-collections.liquid — renders /collections/
  Shows every collection in the store (except the auto-generated "Home page" and "Frontpage" collections)
  as a card grid linking to /collections/<handle>.
{% endcomment %}

<style>
  .collections-index {
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 24px 80px;
  }
  .collections-index__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: 0.04em;
    text-align: center;
    margin: 0 0 12px;
    text-transform: uppercase;
    color: #1a1a1a;
  }
  .collections-index__intro {
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    letter-spacing: 0.05em;
    text-align: center;
    color: #666;
    margin: 0 0 56px;
  }
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 900px) {
    .collections-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .collections-grid { grid-template-columns: 1fr; }
  }

  .collection-card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    background: #f5f4f0;
    aspect-ratio: 4 / 5;
  }
  .collection-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .collection-card:hover .collection-card__image {
    transform: scale(1.04);
  }
  .collection-card__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8e5dd 0%, #d8d4ca 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .collection-card__placeholder svg {
    width: 64px;
    height: 64px;
    opacity: 0.35;
  }
  .collection-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 28px 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 50%);
    color: #fff;
    text-align: center;
  }
  .collection-card__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 6px;
  }
  .collection-card__count {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.9;
  }
  .collection-card__cta {
    margin-top: 12px;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(255,255,255,0.7);
    padding-bottom: 2px;
  }
</style>

<main id="main">
  <section class="collections-index">
    <h1 class="collections-index__title">Shop by Category</h1>
    <p class="collections-index__intro">Browse our full range — refined essentials, considered details, every day.</p>

    <div class="collections-grid">
      {% for collection in collections %}
        {% comment %} Skip the auto-generated "frontpage" / "Home page" collection {% endcomment %}
        {% unless collection.handle == 'frontpage' or collection.handle == 'home-page' or collection.handle == 'home' %}
          <a href="{{ collection.url }}" class="collection-card">
            {% if collection.image %}
              <img src="{{ collection.image | image_url: width: 800 }}"
                   alt="{{ collection.image.alt | default: collection.title | escape }}"
                   class="collection-card__image"
                   loading="lazy">
            {% elsif collection.products.first.featured_image %}
              <img src="{{ collection.products.first.featured_image | image_url: width: 800 }}"
                   alt="{{ collection.title | escape }}"
                   class="collection-card__image"
                   loading="lazy">
            {% else %}
              <div class="collection-card__placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="1"></rect>
                  <circle cx="9" cy="9" r="2"></circle>
                  <path d="M21 15l-5-5L5 21"></path>
                </svg>
              </div>
            {% endif %}

            <div class="collection-card__overlay">
              <h2 class="collection-card__title">{{ collection.title }}</h2>
              <p class="collection-card__count">
                {{ collection.products_count }} {% if collection.products_count == 1 %}product{% else %}products{% endif %}
              </p>
              <span class="collection-card__cta">Shop now</span>
            </div>
          </a>
        {% endunless %}
      {% else %}
        <p style="grid-column: 1 / -1; text-align: center; color: #888; font-family: 'Jost', sans-serif;">
          No collections yet. Create one in Shopify admin under Products → Collections.
        </p>
      {% endfor %}
    </div>
  </section>
</main>
